generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  totalKobo     Int         // Stored in kobo/cents to prevent floating point math bugs
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // The idempotency key ensures if checkout is clicked twice, they only pay once
  idempotencyKey IdempotencyKey?
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  name        String   // Snapshot of the product name at time of purchase
  priceKobo   Int      // Snapshot of the price at time of purchase
  quantity    Int

  order       Order    @relation(fields: [orderId], references: [id])
}

model IdempotencyKey {
  key          String            @id
  orderId      String            @unique
  status       IdempotencyStatus @default(PENDING)
  responseBody Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  order        Order             @relation(fields: [orderId], references: [id])
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  SHIPPED
}

enum Currency {
  NGN
  USD
  EUR
}

enum LedgerReason {
  PURCHASE
  REFUND
  DEPOSIT
  WITHDRAWAL
}

enum IdempotencyStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
