generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ORDER DOMAIN
// ─────────────────────────────────────────────

model Order {
  id                String               @id @default(uuid())
  userId            String
  shippingAddressId String
  currency          Currency             @default(NGN)
  subtotalKobo      Int
  totalKobo         Int                  // Stored in kobo/cents to prevent floating point math bugs
  status            OrderStatus          @default(PENDING)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  idempotencyKey    IdempotencyKey?
  inventoryLedger   InventoryLedgerEntry[] 
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  variantId   String?  // Added from your checkout.ts
  productSlug String   // Added from your checkout.ts
  name        String   // Snapshot of the product name at time of purchase
  imageUrl    String?  // Added from your checkout.ts
  priceKobo   Int      // Snapshot of the price at time of purchase
  quantity    Int

  order       Order    @relation(fields: [orderId], references: [id])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus 
  note      String?
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id])
}

// ─────────────────────────────────────────────
// INVENTORY DOMAIN (New!)
// ─────────────────────────────────────────────

model ProductInventory {
  id                String                 @id @default(uuid())
  productId         String
  variantId         String                 @default("") 
  quantityAvailable Int

  ledgerEntries     InventoryLedgerEntry[]

  // This ensures your code can find the exact item safely
  @@unique([productId, variantId])
}

model InventoryLedgerEntry {
  id           String       @id @default(uuid())
  inventoryId  String
  orderId      String
  reason       LedgerReason
  delta        Int
  balanceAfter Int
  createdAt    DateTime     @default(now())

  inventory    ProductInventory @relation(fields: [inventoryId], references: [id])
  order        Order            @relation(fields: [orderId], references: [id])
}

// ─────────────────────────────────────────────
// INFRASTRUCTURE DOMAIN
// ─────────────────────────────────────────────

model IdempotencyKey {
  key          String            @id
  userId       String            
  requestPath  String            
  status       IdempotencyStatus @default(PENDING)
  responseBody Json?
  expiresAt    DateTime          
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  orderId      String?           @unique 
  order        Order?            @relation(fields: [orderId], references: [id]) 
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  FAILED
  SHIPPED
}

enum Currency {
  NGN
  USD
  EUR
}

enum LedgerReason {
  PURCHASE
  REFUND
  DEPOSIT
  WITHDRAWAL
}

enum IdempotencyStatus {
  PENDING
  PROCESSING
  COMPLETED
  SUCCEEDED // Added to support your checkout.ts logic!
  FAILED
}
