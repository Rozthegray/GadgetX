generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id                String               @id @default(uuid())
  userId            String
  shippingAddressId String      
  currency          Currency             @default(NGN) 
  subtotalKobo      Int         
  totalKobo         Int                  // Stored in kobo/cents to prevent floating point math bugs
  status            OrderStatus          @default(PENDING)
  items             OrderItem[]
  statusHistory     OrderStatusHistory[] // Added for checkout.ts
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  // The idempotency key ensures if checkout is clicked twice, they only pay once
  idempotencyKey    IdempotencyKey?
}

// Added for checkout.ts to track status changes over time
model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  name        String   // Snapshot of the product name at time of purchase
  priceKobo   Int      // Snapshot of the price at time of purchase
  quantity    Int

  order       Order    @relation(fields: [orderId], references: [id])
}

model IdempotencyKey {
  key          String            @id
  userId       String            
  requestPath  String            
  status       IdempotencyStatus @default(PENDING)
  responseBody Json?
  expiresAt    DateTime          
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  orderId      String?           @unique 
  order        Order?            @relation(fields: [orderId], references: [id]) 
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  SHIPPED
}

enum Currency {
  NGN
  USD
  EUR
}

enum LedgerReason {
  PURCHASE
  REFUND
  DEPOSIT
  WITHDRAWAL
}

enum IdempotencyStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
